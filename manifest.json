{
  "manifest_version": 3,
  "version": "1.0",
  "name": "Indicador de Pintores",
  "description": "Adiciona a funcionalidade de registrar o usuário que indicou uma venda no Codxis Web.",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.codxis.api.br/sistema/pages/privado/nfce/emissao/pdv/*"
      ],
      "js": ["src/shared/constants.js", "src/shared/api.js", "src/contents/content.js"],
      "css": ["src/css/custom-select.css"]
    },
    {
      "matches": ["https://web.codxis.api.br/sistema/pages/privado/index/*"],
      "js": ["src/shared/constants.js", "src/shared/api.js", "src/contents/create-referrer.js"],
      "css": ["src/css/modal.css"]
    }
  ],
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://iofeislqynfuerypxrpt.supabase.co/*"]
}
